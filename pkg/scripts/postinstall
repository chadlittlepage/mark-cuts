#!/bin/bash
# mark_cuts postinstall - runs as root after the pkg payload is copied.
#
# Responsibilities:
#   1. Check for Python 3 from python.org and log a warning if missing.
#   2. Drop a Mark_Cuts_NEXT_STEPS.txt on the installing user's Desktop
#      with the two manual Resolve steps that can't be automated.
#
# Note: v1.0.2 installs the script ONLY to /Library/.../Scripts/Utility/.
# Resolve shows Utility scripts at the top level on every page, so one
# install reaches Edit/Color/Fusion/Deliver with zero duplicates.

set +e

# --- 1. Python 3 from python.org check ---
# python.org installs to /Library/Frameworks/Python.framework. Homebrew does
# not. Resolve only sees the python.org install, so warn loudly if absent.
if [ ! -d "/Library/Frameworks/Python.framework" ]; then
    echo "mark_cuts: WARNING - Python 3 from python.org not detected." >&2
    echo "mark_cuts: Install from https://www.python.org/downloads/ before running the script." >&2
    PYTHON_WARNING=" *** Python 3 from python.org was NOT detected on this Mac.
     Install it from https://www.python.org/downloads/ before running.
     (Homebrew Python will not work - Resolve cannot see it.)
"
else
    PYTHON_WARNING=""
fi

# --- 2. Next-steps doc on the installing user's Desktop ---
# Installer.app sets $USER and $HOME to the user who ran the install.
# Fall back to the console user if those are unset or root.
INSTALL_USER="${USER:-$(stat -f '%Su' /dev/console 2>/dev/null)}"
if [ -z "$INSTALL_USER" ] || [ "$INSTALL_USER" = "root" ]; then
    INSTALL_USER=$(stat -f '%Su' /dev/console 2>/dev/null)
fi
INSTALL_HOME=$(eval echo "~$INSTALL_USER" 2>/dev/null)

if [ -n "$INSTALL_HOME" ] && [ -d "$INSTALL_HOME/Desktop" ]; then
    DESK="$INSTALL_HOME/Desktop/Mark_Cuts_NEXT_STEPS.txt"

    cat > "$DESK" 2>/dev/null << NEXTSTEPS
mark_cuts - Next Steps
======================
$PYTHON_WARNING
mark_cuts has been installed system-wide. It will appear at the top of
Workspace > Scripts on every Resolve page (Edit, Color, Fusion, Deliver).

TWO MANUAL STEPS REMAIN inside DaVinci Resolve:

  1. Enable external scripting
     - Open DaVinci Resolve
     - Preferences > System > General
     - Set "External scripting using" to "Local"
     - Save
     - Quit and re-open Resolve

  2. Run the script
     - Open a project with a timeline
     - Workspace > Scripts > mark_cuts

REQUIREMENT: Python 3 must be installed from python.org (not Homebrew).
   https://www.python.org/downloads/

TROUBLESHOOTING
  - Not in the Scripts menu?  Restart Resolve.
  - "Could not connect to DaVinci Resolve."?  External scripting is not
    set to Local. See step 1.
  - Python errors?  Python 3 is not from python.org.

Once everything works you can delete this file.

---
Created by Chad Littlepage
chad.littlepage@gmail.com  |  323.974.0444
NEXTSTEPS

    chown "$INSTALL_USER" "$DESK" 2>/dev/null
    chmod 644 "$DESK" 2>/dev/null
fi

exit 0
